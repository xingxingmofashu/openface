{
  "name": "openface",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.5",
  "description": "",
  "scripts": {
    "dev": "bun run --cwd packages/openface --conditions=browser src/index.ts",
    "prepare": "husky",
    "typecheck": "bunx tsc --noEmit"
  },
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@types/bun": "1.3.5",
      "@types/node": "22.13.9",
      "@tsconfig/bun": "1.0.9",
      "typescript": "5.8.2"
    }
  },
  "devDependencies": {
    "@tsconfig/bun": "catalog:",
    "husky": "^9.1.7"
  },
  "prettier": {
    "semi": false,
    "printWidth": 120
  },
  "overrides": {
    "@types/bun": "catalog:",
    "@types/node": "catalog:"
  }
}
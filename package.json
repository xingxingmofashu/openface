{
  "name": "openface",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.11",
  "description": "A CLI tool for AI-powered natural language processing with Hugging Face Transformers",
  "scripts": {
    "build": "bun run --cwd packages/openface build",
    "dev": "bun run --cwd packages/openface --conditions=browser src/index.ts",
    "docs:dev": "cd packages/docs && mint dev",
    "docs:validate": "cd packages/docs && mint validate",
    "prepare": "husky",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx prettier --check .",
    "format": "bunx prettier --write ."
  },
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@types/bun": "1.3.11",
      "@types/node": "22.13.9",
      "@tsconfig/bun": "1.0.9",
      "typescript": "5.8.2"
    }
  },
  "devDependencies": {
    "@tsconfig/bun": "catalog:",
    "husky": "^9.1.7"
  },
  "prettier": {
    "semi": false,
    "printWidth": 120
  },
  "overrides": {
    "@types/bun": "catalog:",
    "@types/node": "catalog:"
  }
}

{
  "name": "openface",
  "private": true,
  "description": "A CLI tool for AI-powered natural language processing with Hugging Face Transformers",
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@types/bun": "1.3.11",
      "@types/node": "22.13.9",
      "@tsconfig/bun": "1.0.9",
      "typescript": "5.8.2"
    }
  },
  "type": "module",
  "scripts": {
    "build": "bun run --cwd packages/openface build",
    "dev": "bun run --cwd packages/openface --conditions=browser src/index.ts",
    "docs:dev": "cd packages/docs && mint dev",
    "docs:validate": "cd packages/docs && mint validate",
    "prepare": "husky",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt"
  },
  "devDependencies": {
    "@tsconfig/bun": "catalog:",
    "husky": "^9.1.7",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1"
  },
  "overrides": {
    "@types/bun": "catalog:",
    "@types/node": "catalog:"
  },
  "prettier": {
    "printWidth": 120,
    "semi": false
  },
  "packageManager": "bun@1.3.11"
}

#!/usr/bin/env bash
set -euo pipefail

APP=openface
REPO=xingxingmofashu/openface
INSTALL_DIR=${OPENFACE_INSTALL_DIR:-$HOME/.openface/bin}

MUTED='\033[0;2m'
RED='\033[0;31m'
ORANGE='\033[38;5;214m'
NC='\033[0m'

requested_version=${VERSION:-}
binary_path=''
no_modify_path=false
specific_version=''
os=''
arch=''
archive_ext=''
filename=''
url=''
installed_binary_name="$APP"
tmp_dir=''

usage() {
  cat <<EOF
OpenFace Installer

Usage: install [options]

Options:
  -h, --help               Display this help message
  -v, --version <version>  Install a specific version (e.g. 0.1.0)
  -b, --binary <path>      Install from a local binary instead of downloading
      --no-modify-path     Don't modify shell config files

Environment:
  OPENFACE_INSTALL_DIR     Override install directory (default: ~/.openface/bin)
  VERSION                  Same as --version

Examples:
  curl -fsSL https://raw.githubusercontent.com/${REPO}/main/install | bash
  curl -fsSL https://raw.githubusercontent.com/${REPO}/main/install | bash -s -- --version 0.1.0
  ./install --binary /path/to/openface
EOF
}

print_message() {
  local level=$1
  local message=$2
  local color="$NC"

  case "$level" in
    error) color="$RED" ;;
    warning) color="$ORANGE" ;;
  esac

  echo -e "${color}${message}${NC}"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    -v|--version)
      if [[ -z "${2:-}" ]]; then
        print_message error 'Error: --version requires a version argument'
        exit 1
      fi
      requested_version="$2"
      shift 2
      ;;
    -b|--binary)
      if [[ -z "${2:-}" ]]; then
        print_message error 'Error: --binary requires a path argument'
        exit 1
      fi
      binary_path="$2"
      shift 2
      ;;
    --no-modify-path)
      no_modify_path=true
      shift
      ;;
    *)
      print_message warning "Warning: Unknown option '$1'"
      shift
      ;;
  esac
done

require_command() {
  local cmd=$1
  if ! command -v "$cmd" >/dev/null 2>&1; then
    print_message error "Error: '$cmd' is required but not installed."
    exit 1
  fi
}

detect_platform() {
  local raw_os
  raw_os=$(uname -s)

  case "$raw_os" in
    Darwin*) os='darwin' ;;
    Linux*) os='linux' ;;
    MINGW*|MSYS*|CYGWIN*) os='windows' ;;
    *)
      print_message error "Unsupported OS: $raw_os"
      exit 1
      ;;
  esac

  arch=$(uname -m)
  case "$arch" in
    aarch64|arm64) arch='arm64' ;;
    x86_64|amd64) arch='x64' ;;
    *)
      print_message error "Unsupported architecture: $arch"
      exit 1
      ;;
  esac

  if [[ "$os" == 'darwin' && "$arch" == 'x64' ]]; then
    local rosetta_flag
    rosetta_flag=$(sysctl -n sysctl.proc_translated 2>/dev/null || echo 0)
    if [[ "$rosetta_flag" == '1' ]]; then
      arch='arm64'
    fi
  fi

  local is_musl=false
  if [[ "$os" == 'linux' ]]; then
    if [[ -f /etc/alpine-release ]]; then
      is_musl=true
    elif command -v ldd >/dev/null 2>&1 && ldd --version 2>&1 | grep -qi musl; then
      is_musl=true
    fi
  fi

  local needs_baseline=false
  if [[ "$arch" == 'x64' ]]; then
    case "$os" in
      linux)
        if ! grep -qwi avx2 /proc/cpuinfo 2>/dev/null; then
          needs_baseline=true
        fi
        ;;
      windows)
        local ps out
        ps='(Add-Type -MemberDefinition "[DllImport(""kernel32.dll"")] public static extern bool IsProcessorFeaturePresent(int ProcessorFeature);" -Name Kernel32 -Namespace Win32 -PassThru)::IsProcessorFeaturePresent(40)'
        out=''
        if command -v powershell.exe >/dev/null 2>&1; then
          out=$(powershell.exe -NoProfile -NonInteractive -Command "$ps" 2>/dev/null || true)
        elif command -v pwsh >/dev/null 2>&1; then
          out=$(pwsh -NoProfile -NonInteractive -Command "$ps" 2>/dev/null || true)
        fi
        out=$(echo "$out" | tr -d '\r' | tr '[:upper:]' '[:lower:]' | tr -d '[:space:]')
        if [[ "$out" != 'true' && "$out" != '1' ]]; then
          needs_baseline=true
        fi
        ;;
    esac
  fi

  local target="$os-$arch"
  if [[ "$needs_baseline" == 'true' ]]; then
    target="$target-baseline"
  fi
  if [[ "$is_musl" == 'true' ]]; then
    target="$target-musl"
  fi

  case "$target" in
    linux-x64|linux-x64-baseline|linux-arm64|linux-x64-musl|linux-x64-baseline-musl|linux-arm64-musl|darwin-arm64|windows-x64|windows-x64-baseline|windows-arm64)
      ;;
    darwin-x64|darwin-x64-baseline)
      print_message error 'Unsupported platform: macOS Intel is not published by this repository.'
      exit 1
      ;;
    *)
      print_message error "Unsupported OS/Arch: $os/$arch"
      exit 1
      ;;
  esac

  if [[ "$os" == 'windows' ]]; then
    archive_ext='.zip'
  else
    archive_ext='.tar.gz'
  fi

  filename="$APP-$target$archive_ext"
}

fetch_version() {
  require_command curl

  if [[ -z "$requested_version" ]]; then
    url="https://github.com/${REPO}/releases/latest/download/${filename}"
    specific_version=$(curl -fsSL "https://api.github.com/repos/${REPO}/releases/latest" | sed -n 's/.*"tag_name": *"v\{0,1\}\([^"]*\)".*/\1/p' | head -n 1)
    if [[ -z "$specific_version" ]]; then
      print_message error 'Failed to fetch version information'
      exit 1
    fi
  else
    requested_version=${requested_version#v}
    specific_version="$requested_version"
    url="https://github.com/${REPO}/releases/download/v${requested_version}/${filename}"

    local http_status
    http_status=$(curl -sI -o /dev/null -w '%{http_code}' "https://github.com/${REPO}/releases/tag/v${requested_version}")
    if [[ "$http_status" == '404' ]]; then
      print_message error "Error: Release v${requested_version} not found"
      print_message info "Available releases: https://github.com/${REPO}/releases"
      exit 1
    fi
  fi
}

check_version() {
  if command -v "$APP" >/dev/null 2>&1; then
    local installed_version
    installed_version=$($APP --version 2>/dev/null || echo '')
    installed_version=${installed_version#v}
    if [[ "$installed_version" == "$specific_version" ]]; then
      print_message info "${MUTED}Version ${NC}${specific_version}${MUTED} already installed${NC}"
      exit 0
    fi
  fi
}

find_extracted_binary() {
  local dir=$1
  find "$dir" -type f \( -name 'openface' -o -name 'openface.exe' \) | head -n 1
}

download_and_install() {
  local archive_path extracted_binary
  tmp_dir=$(mktemp -d "${TMPDIR:-/tmp}/openface_install_XXXXXX")
  archive_path="$tmp_dir/$filename"
  trap '[[ -n "$tmp_dir" ]] && rm -rf "$tmp_dir"' EXIT

  print_message info "${MUTED}Installing ${NC}${APP} ${MUTED}version: ${NC}${specific_version}"
  curl -fL# -o "$archive_path" "$url"

  if [[ "$archive_ext" == '.zip' ]]; then
    require_command unzip
    unzip -q "$archive_path" -d "$tmp_dir"
  else
    require_command tar
    tar -xzf "$archive_path" -C "$tmp_dir"
  fi

  extracted_binary=$(find_extracted_binary "$tmp_dir")
  if [[ -z "$extracted_binary" ]]; then
    print_message error 'Error: Could not locate extracted openface binary'
    exit 1
  fi

  installed_binary_name=$(basename "$extracted_binary")
  mkdir -p "$INSTALL_DIR"
  cp "$extracted_binary" "$INSTALL_DIR/$installed_binary_name"
  chmod 755 "$INSTALL_DIR/$installed_binary_name"
}

install_from_binary() {
  if [[ ! -f "$binary_path" ]]; then
    print_message error "Error: Binary not found at ${binary_path}"
    exit 1
  fi

  installed_binary_name=$(basename "$binary_path")
  mkdir -p "$INSTALL_DIR"
  cp "$binary_path" "$INSTALL_DIR/$installed_binary_name"
  chmod 755 "$INSTALL_DIR/$installed_binary_name"
}

add_to_path() {
  local config_file=$1
  local command=$2

  if [[ ! -f "$config_file" ]]; then
    return
  fi

  if grep -Fqx "$command" "$config_file"; then
    return
  fi

  if [[ -w "$config_file" ]]; then
    printf '\n# openface\n%s\n' "$command" >> "$config_file"
    print_message info "${MUTED}Added ${NC}${INSTALL_DIR}${MUTED} to PATH in ${NC}${config_file}"
  else
    print_message warning "Manually add this to your shell config:"
    print_message info "  $command"
  fi
}

maybe_update_path() {
  if [[ "$no_modify_path" == 'true' ]]; then
    return
  fi

  if [[ ":$PATH:" == *":$INSTALL_DIR:"* ]]; then
    return
  fi

  local current_shell config_file command xdg_config_home
  current_shell=$(basename "${SHELL:-sh}")
  xdg_config_home=${XDG_CONFIG_HOME:-$HOME/.config}
  config_file=''
  command="export PATH=$INSTALL_DIR:\$PATH"

  case "$current_shell" in
    fish)
      command="fish_add_path $INSTALL_DIR"
      for candidate in "$HOME/.config/fish/config.fish"; do
        if [[ -f "$candidate" ]]; then
          config_file="$candidate"
          break
        fi
      done
      ;;
    zsh)
      for candidate in "${ZDOTDIR:-$HOME}/.zshrc" "${ZDOTDIR:-$HOME}/.zshenv" "$xdg_config_home/zsh/.zshrc" "$xdg_config_home/zsh/.zshenv"; do
        if [[ -f "$candidate" ]]; then
          config_file="$candidate"
          break
        fi
      done
      ;;
    bash)
      for candidate in "$HOME/.bashrc" "$HOME/.bash_profile" "$HOME/.profile" "$xdg_config_home/bash/.bashrc" "$xdg_config_home/bash/.bash_profile"; do
        if [[ -f "$candidate" ]]; then
          config_file="$candidate"
          break
        fi
      done
      ;;
  esac

  if [[ -n "$config_file" ]]; then
    add_to_path "$config_file" "$command"
  else
    print_message warning 'No writable shell config file was found. Add this manually:'
    print_message info "  $command"
  fi
}

if [[ -n "$binary_path" ]]; then
  install_from_binary
  specific_version='local'
else
  detect_platform
  fetch_version
  check_version
  download_and_install
fi

maybe_update_path

if [[ -n "${GITHUB_ACTIONS-}" && "${GITHUB_ACTIONS}" == 'true' ]]; then
  echo "$INSTALL_DIR" >> "$GITHUB_PATH"
fi

echo -e ''
echo -e "${MUTED}Installed ${NC}${APP}${MUTED} to ${NC}${INSTALL_DIR}/${installed_binary_name}"
echo -e "${MUTED}Run ${NC}${APP} --help${MUTED} to get started.${NC}"
